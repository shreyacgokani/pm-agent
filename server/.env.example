PORT=5001
DATABASE_URL=postgresql://pmagent:pmagent@localhost:5432/pmagent
# Sarah voice — OpenAI neural TTS (shimmer = warm female, nova = energetic female)
OPENAI_TTS_VOICE=shimmer
OPENAI_TTS_MODEL=tts-1
# Realtime voice agent (GA API — do not use beta header)
OPENAI_REALTIME_MODEL=gpt-realtime

# Optional: server-level GitHub token fallback
GITHUB_TOKEN=

# GitHub OAuth (recommended for Integrations sign-in)
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must match GITHUB_CALLBACK_URL below
# Optional: override auto-registered OAuth credentials (stored in server/data/github-oauth.json)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth callback (defaults to http://localhost:3000/api/github/callback via Vite proxy)
GITHUB_CALLBACK_URL=http://localhost:3000/api/github/callback
FRONTEND_URL=http://localhost:3000
