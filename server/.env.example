PORT=5001
DATABASE_URL=postgresql://pmagent:pmagent@localhost:5432/pmagent
# Sarah voice — OpenAI neural TTS (shimmer = warm female, nova = energetic female)
OPENAI_TTS_VOICE=shimmer
OPENAI_TTS_MODEL=tts-1

# Optional: server-level GitHub token fallback
GITHUB_TOKEN=

# GitHub OAuth (recommended) — create at https://github.com/settings/developers
# Authorization callback URL: http://localhost:5001/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5001/api/github/callback
FRONTEND_URL=http://localhost:3000
